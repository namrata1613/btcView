#!/usr/bin/env bash

set -e
REPO=~/research/FreshDiskANN-baseline
WORK=~/research/work
DATA=~/research/data/sift1m
SM=$WORK/sm_iso
GTDIR=$WORK/sift100k_gt_inserts_only
BASEPFX=sift100k

set -euo pipefail

# Load configuration
source ~/research/work/sm_iso/config.env

# Path to executable
DRV="$REPO/build/tests/overall_performance"

# Verify executable exists
if [ ! -x "$DRV" ]; then
    echo "ERROR: Executable not found or not executable:"
    echo "  $DRV"
    exit 1
fi

for c in $GRID; do
    echo "===== MERGE TRIAL C=$c ====="

    TR="$SM/trial_c$c"
    rm -rf "$TR"
    mkdir -p "$TR"

    cp "$SM/pristine/${BASEPFX}"* "$TR"/

    SP="$TR/$BASEPFX"

    ########################################
    # Checkpoint 0
    ########################################
    INSERTS_ONLY=1 \
        "$DRV" \
        "$TYPE" \
        "$BASEDATA" \
        "$LDISK" \
        "$RDISK" \
        "$ALPHA" \
        0 \
        0 \
        "$SP" \
        "$QUERY" \
        "$GTDIR" \
        10 \
        "$BEAM" \
        100 \
        0 \
        "$c" \
        $LSEARCH \
        > "$SM/merge_c${c}_ckpt0.log" 2>&1

    ########################################
    # Checkpoint 1
    ########################################
    setsid bash -c "
    INSERTS_ONLY=1 \
    \"$DRV\" \
        \"$TYPE\" \
        \"$BASEDATA\" \
        \"$LDISK\" \
        \"$RDISK\" \
        \"$ALPHA\" \
        0 \
        0 \
        \"$SP\" \
        \"$QUERY\" \
        \"$GTDIR\" \
        10 \
        \"$BEAM\" \
        100 \
        1 \
        "$c" \
        $LSEARCH" \
        > "$SM/merge_c${c}_ckpt1.log" 2>&1 &

    PID=$!

    for t in $(seq 1 900); do
        if grep -q "^Batch: " "$SM/merge_c${c}_ckpt1.log"; then
            break
        fi
        sleep 1
    done

    kill -- -"$PID" 2>/dev/null || true
    sleep 2

    echo "c=$c ckpt1 recall rows:"
    grep -E "^[[:space:]]*(50|75|100)[[:space:]]" \
        "$SM/merge_c${c}_ckpt1.log" | head -3

done

echo "=== Phase 1b DONE ==="
