cd ~/research/work/SPFresh/Release

SET=sift100k_update_set
TRUTH=sift100k_update_truth

mkdir -p ~/research/work/spfresh/sift100k_trace

for i in $(seq 0 9); do
  ./usefultool -GenTrace true --vectortype float \
    --VectorPath ~/research/work/spfresh/sift_base_200k.bin \
    --filetype DEFAULT \
    --UpdateSize 10000 \
    --BaseNum 100000 \
    --ReserveNum 100000 \
    --CurrentListFileName sift100k_update_current \
    --ReserveListFileName sift100k_update_reserve \
    --TraceFileName ~/research/work/spfresh/sift100k_trace/sift100k_update_trace \
    --NewDataSetFileName ~/research/work/spfresh/sift100k_trace/${SET} \
    -d 128 \
    --Batch $i \
    -f DEFAULT

  sed -i "s#^VectorPath=.*#VectorPath=$HOME/research/work/spfresh/sift100k_trace/${SET}${i}#" genTruth_sift100k.ini

  sed -i "s#^TruthPath=.*#TruthPath=$HOME/research/work/spfresh/sift100k_trace/${TRUTH}${i}#" genTruth_sift100k.ini

  ./ssdserving genTruth_sift100k.ini

  ./usefultool -ConvertTruth true --vectortype float \
    --VectorPath ~/research/work/spfresh/sift_base_200k.bin \
    --filetype DEFAULT \
    --UpdateSize 10000 \
    --BaseNum 100000 \
    --ReserveNum 100000 \
    --CurrentListFileName sift100k_update_current \
    --ReserveListFileName sift100k_update_reserve \
    --TraceFileName ~/research/work/spfresh/sift100k_trace/sift100k_update_trace \
    --NewDataSetFileName ~/research/work/spfresh/sift100k_trace/${SET} \
    -d 128 \
    --Batch $i \
    -f DEFAULT \
    --truthPath ~/research/work/spfresh/sift100k_trace/${TRUTH} \
    --truthType DEFAULT \
    --querySize 10000 \
    --resultNum 100

done 2>&1 | tee ~/research/work/logs/spfresh_trace_$(date +%F).log

